;;; PRINCIPLE 5: Corporate Asset Protection Doctrine
;;;
(define-principle corporate-asset-protection-doctrine
  #:name "Corporate Asset Protection Doctrine"
  #:confidence 0.94
  #:domain '(company-law property-law asset-protection)
  #:description "Doctrine for protecting corporate assets from third-party claims"
  
  #:core-elements '(
    (corporate-asset-identification "Corporate asset identified")
    (asset-ownership-establishment "Asset ownership established")
    (third-party-claim-analysis "Third-party claim analyzed")
    (claim-basis-assessment "Claim basis assessed")
    (asset-protection-framework "Asset protection framework established")
    (protection-conclusion "Protection conclusion established")
  )
  
  #:test-methodology
  "Apply the corporate asset protection doctrine in 6 steps:
  
  1. **Identify Corporate Asset**:
     - What is the corporate asset?
     - How is it identified?
     - What is its value?
     - What is its importance?
  
  2. **Establish Asset Ownership**:
     - Who owns the asset?
     - Is ownership documented?
     - Is ownership legitimate?
     - Is ownership protected?
  
  3. **Analyze Third-Party Claim**:
     - What is the third-party claim?
     - What is the basis for the claim?
     - Is the claim legitimate?
     - Is the claim defensible?
  
  4. **Assess Claim Basis**:
     - What is the legal basis for the claim?
     - Is the basis valid?
     - Is the basis defensible?
     - What is the strength of the claim?
  
  5. **Establish Asset Protection Framework**:
     - How are assets protected?
     - What defenses exist?
     - What remedies exist?
     - How are defenses applied?
  
  6. **Conclude Protection**:
     - Is asset protected?
     - What is the scope of protection?
     - Is protection defensible?
     - What is the confidence level?"
  
  #:red-flags '(
    (corporate-asset-not-identified 0.92 "Corporate asset not identified")
    (asset-ownership-not-established 0.94 "Asset ownership not established")
    (third-party-claim-valid 0.93 "Third-party claim valid")
    (claim-basis-strong 0.91 "Claim basis strong")
    (asset-protection-inadequate 0.90 "Asset protection inadequate")
  )
  
  #:case-application
  "Case 2025-137857 - Platform Asset Protection:
  
  **Corporate Asset Identification**:
  - Asset: Shopify e-commerce platform
  - Identification: Platform owned by RegimA Zone Ltd
  - Value: R8.85M+ investment
  - Importance: Critical business infrastructure
  
  **Asset Ownership Establishment**:
  - Owner: RegimA Zone Ltd (Daniel's company)
