(define (mentions-interdict? content)
  "Check if content mentions interdict"
  (or (string-contains content "interdict")
      (string-contains content "interim relief")
      (string-contains content "urgent application")))

(define (mentions-entity? content entity-key)
  "Check if content mentions an entity"
  (let ((entity-data (assoc-ref entity-registry-v9 entity-key)))
    (if entity-data
        (or (string-contains content (assoc-ref entity-data 'full-name))
            (string-contains content entity-key))
        #f)))

(define (mentions-financial-allegations? content)
  "Check if content mentions financial allegations"
  (or (string-contains content "R500")
      (string-contains content "director loan")
      (string-contains content "payment")
      (string-contains content "financial")))

(define (mentions-retaliation? content)
  "Check if content mentions retaliation"
  (or (string-contains content "retaliation")
      (string-contains content "card cancellation")
      (string-contains content "sabotage")))

(define (mentions-regulatory-requirements? content)
  "Check if content mentions regulatory requirements"
  (or (string-contains content "EU Responsible Person")
      (string-contains content "regulatory")
      (string-contains content "compliance")))

(define (mentions-response-requirements? content)
  "Check if content mentions response requirements"
  (or (string-contains content "24-48 hour")
      (string-contains content "response requirement")
      (string-contains content "emergency")))

