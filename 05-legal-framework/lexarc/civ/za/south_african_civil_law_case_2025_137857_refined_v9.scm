;;;
;;; LEGAL ASPECTS RESOLUTION ENGINE - v9 Enhanced
;;;

(define (resolve-ad-paragraph-legal-aspects-v9 ad-paragraph entities events)
  "Resolve legal aspects for an AD paragraph with optimal resolution pathways"
  (let* (
    ;; Extract paragraph metadata
    (para-id (assoc-ref ad-paragraph 'id))
    (para-content (assoc-ref ad-paragraph 'content))
    (para-priority (assoc-ref ad-paragraph 'priority))
    
    ;; Identify entities mentioned
    (entities-mentioned (identify-entities para-content entities))
    
    ;; Identify events referenced
    (events-referenced (identify-events para-content events))
    
    ;; Detect legal aspects
    (legal-aspects (detect-legal-aspects para-content))
    
    ;; Calculate void ab initio strength
    (void-strength (calculate-void-ab-initio-strength-v9
                     para-content entities-mentioned events-referenced))
    
    ;; Detect cross-paragraph patterns
    (cross-patterns (detect-cross-paragraph-patterns-v9
                      para-id para-content entities events))
    
    ;; Identify material omissions
    (material-omissions (identify-material-omissions-v9
                          para-content entities-mentioned))
    
    ;; Analyze multi-actor coordination
    (coordination-analysis (analyze-multi-actor-coordination-v9
                             entities-mentioned events-referenced))
    
    ;; Generate evidence network map
    (evidence-network (generate-evidence-network-map-v9
                        para-id entities-mentioned events-referenced))
    
    ;; Compute temporal causation confidence
    (causation-confidence (compute-temporal-causation-confidence-v9
                            events-referenced))
    
    ;; Analyze systemic bad faith indicators
    (bad-faith-analysis (analyze-systemic-bad-faith-indicators-v9
                          para-content entities-mentioned events-referenced))
    
    ;; Generate comprehensive rebuttal framework
    (rebuttal-framework (generate-comprehensive-rebuttal-framework-v9
                          para-id para-content legal-aspects
                          entities-mentioned events-referenced
                          void-strength material-omissions))
    
    ;; Optimize legal resolution pathway
    (resolution-pathway (optimize-legal-resolution-pathway-v9
                          para-id legal-aspects void-strength
                          material-omissions coordination-analysis))
  )
  
  ;; Return comprehensive analysis
  (list
    (cons 'paragraph-id para-id)
    (cons 'priority para-priority)
    (cons 'entities-mentioned entities-mentioned)
    (cons 'events-referenced events-referenced)
    (cons 'legal-aspects legal-aspects)
    (cons 'void-ab-initio-strength void-strength)
    (cons 'cross-paragraph-patterns cross-patterns)
    (cons 'material-omissions material-omissions)
    (cons 'coordination-analysis coordination-analysis)
    (cons 'evidence-network evidence-network)
    (cons 'causation-confidence causation-confidence)
    (cons 'bad-faith-analysis bad-faith-analysis)
    (cons 'rebuttal-framework rebuttal-framework)
    (cons 'resolution-pathway resolution-pathway)
  )))

