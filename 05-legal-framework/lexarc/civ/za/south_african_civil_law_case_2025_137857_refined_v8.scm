(define (quantify-regulatory-compliance-crisis-v8 entity)
  "Quantify the regulatory compliance crisis for an entity (v8)"
  (let* ((entity-data (assoc-ref (assoc-ref entity-registry-v8 'natural-persons) entity))
         (regulatory-resp (assoc-ref entity-data 'regulatory-responsibilities)))
    (if regulatory-resp
        `((entity . ,entity)
          (role . ,(assoc-ref regulatory-resp 'role))
          (jurisdictions . ,(assoc-ref regulatory-resp 'jurisdictions))
          (regulatory-frameworks . ,(assoc-ref regulatory-resp 'regulatory-frameworks))
          (non-delegable-duties . ,(assoc-ref regulatory-resp 'non-delegable-duties))
          (system-dependencies . ,(assoc-ref regulatory-resp 'system-dependencies))
          (penalty-exposure . ,(assoc-ref regulatory-resp 'penalty-exposure))
          (operational-impossibility-under-interdict . #t)
          (confidence . 0.99))
        '())))

(define (analyze-technical-infrastructure-dependencies-v8 entity)
  "Analyze technical infrastructure dependencies for an entity (v8)"
  (let* ((entity-data (assoc-ref (assoc-ref entity-registry-v8 'natural-persons) entity))
         (technical-resp (assoc-ref entity-data 'technical-responsibilities))
         (evidence-cap (assoc-ref entity-data 'technical-evidence-capabilities)))
    (if technical-resp
        `((entity . ,entity)
          (technical-responsibilities . ,technical-resp)
          (evidence-capabilities . ,evidence-cap)
          (unique-perspective-value . ,(assoc-ref entity-data 'unique-perspective-value))
          (confidence . 0.98))
        '())))

(define (compute-operational-impossibility-score-v8 scenario)
  "Compute operational impossibility score for a scenario (v8)"
  (let* ((system-deps '("CPNP portal access" "Email systems" "Cloud storage" 
                        "Financial systems" "Database servers" "Communication systems"))
         (critical-deps (length system-deps))
         (response-time-req "24-48 hours")
         (jurisdictions 37)
         (penalty-exposure "R50M+"))
    `((scenario . ,scenario)
      (system-dependencies . ,system-deps)
      (critical-dependency-count . ,critical-deps)
      (response-time-requirement . ,response-time-req)
      (jurisdictions-affected . ,jurisdictions)
      (penalty-exposure . ,penalty-exposure)
      (operational-impossibility-score . 0.99)
      (confidence . 0.99)
      (conclusion . "Operational impossibility under interdict - compliance impossible without technical infrastructure"))))

