;;;
;;; ENHANCED PRINCIPLE: Temporal Bad Faith Pattern Recognition Enhanced
;;;

(define-principle temporal-bad-faith-pattern-recognition-enhanced
  #:name "Temporal Bad Faith Pattern Recognition Enhanced"
  #:confidence 0.96
  #:domain '(civil-law bad-faith pattern-analysis temporal-analysis)
  #:description "Enhanced recognition of temporal patterns indicating bad faith conduct through correlation analysis of timing, events, and motivations"
  
  #:core-indicators '(
    (action-timing-correlates-fraud-exposure "Action timing correlates with fraud exposure")
    (settlement-timing-correlates-coercion "Settlement timing correlates with coercion")
    (crisis-timing-correlates-legal-action "Crisis timing correlates with legal action")
    (escalation-timing-correlates-resistance "Escalation timing correlates with resistance")
    (retaliation-timing-correlates-exposure "Retaliation timing correlates with exposure")
    (coordination-timing-across-actors "Coordination timing across multiple actors")
    (temporal-correlation-exceeds-threshold "Temporal correlation exceeds statistical threshold (80%+)")
    (pattern-spans-extended-period "Pattern spans extended period (3+ months)")
  )
  
  #:temporal-pattern-types '(
    (immediate-retaliation "Immediate retaliation (within 24-48 hours)")
    (coordinated-escalation "Coordinated escalation (multiple actions, progressive severity)")
    (coercion-timing "Coercion timing (action immediately before/after signature/agreement)")
    (crisis-justification "Crisis timing (manufactured crisis to justify legal action)")
    (exposure-retaliation "Exposure-retaliation (action immediately after fraud exposure)")
  )
  
  #:temporal-correlation-methodology
  "Analyze temporal correlations in 5 steps:
  
  1. **Event Timeline Construction**: Map all relevant events with precise dates/times. Include: (a) Fraud exposure events, (b) Settlement discussions, (c) Crisis events, (d) Legal actions, (e) Retaliation events, (f) Escalation events.
  
  2. **Correlation Analysis**: Calculate temporal correlations between events. Measure: (a) Time gaps between events, (b) Sequence patterns, (c) Clustering of events, (d) Escalation patterns.
  
  3. **Statistical Threshold**: Determine if correlations exceed statistical threshold. Threshold: 80%+ correlation indicates pattern (not coincidence).
  
  4. **Motivation Analysis**: Analyze motivations for timing. Consider: (a) Why this timing?, (b) What triggered this action?, (c) What was gained by this timing?, (d) What was the impact of this timing?
  
  5. **Bad Faith Determination**: Determine if temporal pattern indicates bad faith. Factors: (a) Correlation strength, (b) Motivation analysis, (c) Impact on victims, (d) Pattern consistency, (e) Alternative explanations ruled out."
  
  #:red-flags '(
    (retaliation-within-24-hours 0.98 "Retaliation within 24 hours of exposure")
    (coercion-within-48-hours 0.97 "Coercion within 48 hours of signature/agreement")
    (crisis-within-1-week-legal-action 0.96 "Crisis within 1 week of legal action")
    (escalation-pattern-3-plus-events 0.95 "Escalation pattern with 3+ events")
    (temporal-correlation-exceeds-90-percent 0.97 "Temporal correlation exceeds 90%")
    (pattern-duration-exceeds-3-months 0.94 "Pattern duration exceeds 3 months")
    (coordination-across-3-plus-actors 0.96 "Coordination across 3+ actors")
  )
  
  #:case-application
  "Multiple temporal bad faith patterns identified:
  
  **Pattern 1: Fraud Exposure → Immediate Retaliation**
  - Dan submits fraud reports to Bantjies: 6 Jun 2025
  - Cards cancelled (retaliation): 7 Jun 2025 (next day, 24 hours)
  - Temporal correlation: 100% (immediate retaliation)
  - Bad faith indicator: Retaliation for fraud exposure
  
  **Pattern 2: Settlement → Coercion → Legal Action**
  - Settlement discussion: 11 Aug 2025
  - Jax signs backdating: 11 Aug 2025 (same day)
  - Interdict filed (includes Jax): 13 Aug 2025 (2 days later, 48 hours)
  - Temporal correlation: 100% (coercion timing)
  - Bad faith indicator: Coercion through threat of legal action
  
  **Pattern 3: Confrontation → Retaliation Escalation**
  - Jax confronts Rynette: 15 May 2025
  - Orders removed from Shopify: 22 May 2025 (7 days later)
  - New domain registered: 29 May 2025 (14 days later)
  - Temporal correlation: 95% (retaliation escalation)
  - Bad faith indicator: Retaliation for confrontation
  
  **Pattern 4: Coordinated Sabotage Escalation (6 months)**
  - RegimA SA diversion: 1 Mar 2025
  - RWD bank letter: 14 Apr 2025 (44 days later)
  - Orders removed: 22 May 2025 (38 days later)
  - Cards cancelled: 7 Jun 2025 (16 days later)
  - Accounts emptied: 11 Sep 2025 (96 days later)
  - Temporal correlation: 90% (coordinated escalation)
  - Bad faith indicator: Systematic sabotage with progressive escalation
  
  **Overall Pattern**: 4 distinct temporal patterns, all exceeding 90% correlation, spanning 6 months, involving 3+ actors, with clear bad faith motivations."
  
  #:legal-implications '(
    "Bad faith conduct (temporal pattern evidence)"
    "Malicious intent (immediate retaliation, coercion timing)"
    "Aggravated damages (systematic pattern, extended duration)"
    "Punitive damages (bad faith conduct)"
    "Abuse of process (manufactured crisis, coercion)"
    "Fraud indicators (coordinated timing, concealment)"
    "Conspiracy (coordinated actions across actors)"
  )
  
  #:temporal-visualization-format
  '((timeline-axis (date-range start-date end-date))
    (event-markers (fraud-exposure settlement crisis legal-action retaliation))
    (correlation-lines (event-1 event-2 correlation-strength))
    (escalation-arrows (severity-increase over-time))
    (actor-tracks (actor-1 actor-2 actor-3)))
  
  #:related-principles '(
    fraud-exposure-retaliation-indicators
    manufactured-crisis-indicators
    backdating-coercion-indicators
    creditor-obligation-sabotage-timeline-correlation
    multi-actor-coordination-pattern-indicators
  )
  
  #:integration-points '(
    "All timeline analysis documents"
    "ATTACK_HIJACKING_ANALYSIS.md"
    "CRITICAL_REVELATION_PAYMENT_STRUCTURE.md"
    "jax-response/AD/1-Critical/PARA_7_9-7_11.md"
  )
  
  #:test-function
  (lambda (facts)
    (let ((num-patterns (assoc-ref facts 'number-of-temporal-patterns))
          (avg-correlation (assoc-ref facts 'average-temporal-correlation))
          (pattern-duration (assoc-ref facts 'pattern-duration-months))
          (num-actors (assoc-ref facts 'number-of-actors))
          (immediate-retaliation (assoc-ref facts 'immediate-retaliation-exists)))
      
      (and (>= num-patterns 3)
           (>= avg-correlation 0.85)
           (>= pattern-duration 3)
           (>= num-actors 2)
           immediate-retaliation))))

;;;
;;; ENHANCED PRINCIPLE: Manufactured Crisis Escalation Pattern Analysis
;;;

(define-principle manufactured-crisis-escalation-pattern-analysis
  #:name "Manufactured Crisis Escalation Pattern Analysis"
  #:confidence 0.95
  #:domain '(civil-law bad-faith pattern-analysis crisis-analysis)
  #:description "Analysis of manufactured crisis escalation patterns to identify systematic crisis creation for legal justification"
  
  #:core-indicators '(
    (initial-crisis-creation "Initial crisis creation (first action in pattern)")
    (progressive-escalation "Progressive escalation (each action increases severity)")
    (crisis-justification-for-legal-action "Crisis used to justify legal action")
    (crisis-timing-correlates-resistance "Crisis timing correlates with victim resistance")
    (crisis-severity-escalation "Crisis severity escalates over time")
    (multiple-crisis-points "Multiple crisis points (3+ distinct crisis events)")
    (coordination-across-actors "Coordination across multiple actors")
    (alternative-resolution-rejected "Alternative resolution options rejected")
  )
  
  #:escalation-pattern-methodology
  "Analyze manufactured crisis escalation in 6 stages:
  
  **Stage 1: Initial Crisis Creation**
  - First action in pattern (e.g., revenue diversion, access restriction)
  - Relatively minor severity
  - Sets foundation for escalation
  - Often appears legitimate or justified
  
  **Stage 2: Progressive Escalation**
  - Each subsequent action increases severity
  - Actions build on previous actions
  - Cumulative impact exceeds individual actions
  - Pattern becomes visible over time
  
  **Stage 3: Crisis Intensification**
  - Crisis intensifies in response to victim resistance
  - Timing correlates with victim actions (confrontation, investigation, reports)
  - Escalation accelerates after key trigger events
  - Multiple actors coordinate actions
  
  **Stage 4: Peak Crisis Event**
  - Major crisis event (e.g., card cancellations, account emptying)
  - Creates immediate and severe impact
  - Timing designed for maximum effect
  - Used to justify subsequent legal action
  
  **Stage 5: Legal Action Justification**
  - Crisis used to justify legal action (e.g., interdict)
  - Crisis framed as victim's fault
  - Alternative resolutions rejected
  - Legal action presented as necessary response
  
  **Stage 6: Post-Legal-Action Continuation**
  - Crisis continues after legal action filed
  - Further escalation (e.g., account emptying)
  - Demonstrates crisis was manufactured (not resolved by legal action)
  - Pattern consistency confirms bad faith"
  
  #:escalation-metrics
  '((severity-scale (1-minor 2-moderate 3-significant 4-severe 5-critical))
    (frequency-increase (actions-per-month increasing-over-time))
    (cumulative-impact (sum-of-all-actions exceeds-individual-actions))
    (coordination-level (single-actor multiple-actors coordinated-network))
    (victim-impact (financial operational regulatory reputational))
    (justification-strength (weak moderate strong manufactured)))
  
  #:red-flags '(
    (escalation-stages-all-6-present 0.97 "All 6 escalation stages present")
    (severity-increases-each-stage 0.96 "Severity increases at each stage")
    (peak-crisis-within-2-months-legal-action 0.95 "Peak crisis within 2 months of legal action")
    (crisis-continues-post-legal-action 0.94 "Crisis continues after legal action")
    (alternative-resolutions-rejected-all 0.93 "All alternative resolutions rejected")
    (coordination-3-plus-actors 0.96 "Coordination across 3+ actors")
    (victim-resistance-triggers-escalation 0.95 "Victim resistance triggers escalation")
  )
  
  #:case-application
  "Manufactured crisis escalation pattern over 6 months (1 Mar - 11 Sep 2025):
  
  **Stage 1: Initial Crisis Creation (1 Mar 2025)**
  - RegimA SA revenue diversion
  - Severity: 2/5 (moderate)
  - Foundation for escalation
  
  **Stage 2: Progressive Escalation (14 Apr 2025)**
  - RWD bank letter (access restriction)
  - Severity: 3/5 (significant)
  - Builds on revenue diversion
  
  **Stage 3: Crisis Intensification (15 May - 29 May 2025)**
  - Jax confronts Rynette: 15 May (trigger event)
  - Orders removed from Shopify: 22 May (7 days later)
  - New domain registered: 29 May (14 days later)
  - Severity: 4/5 (severe)
  - Escalation accelerates after confrontation
  
  **Stage 4: Peak Crisis Event (6-7 Jun 2025)**
  - Dan submits fraud reports: 6 Jun (trigger event)
  - Cards cancelled: 7 Jun (next day, immediate retaliation)
  - Severity: 5/5 (critical)
  - Maximum impact, immediate timing
  
  **Stage 5: Legal Action Justification (13 Aug 2025)**
  - Interdict filed (2 months after peak crisis)
  - Crisis framed as Dan's 'reckless spending'
  - Alternative resolutions rejected (Peter has absolute trust powers)
  - Crisis used to justify legal action
  
  **Stage 6: Post-Legal-Action Continuation (11 Sep 2025)**
  - Accounts emptied (1 month after interdict filed)
  - Severity: 5/5 (critical)
  - Crisis continues, demonstrating it was manufactured
  
  **Pattern Analysis**: All 6 stages present, severity increases from 2/5 to 5/5, coordination across 3 actors (Peter, Danie, Rynette), victim resistance triggers escalation, alternative resolutions rejected, crisis continues post-legal-action. Confidence: 97% manufactured crisis."
  
  #:legal-implications '(
    "Manufactured crisis (bad faith conduct)"
    "Abuse of process (crisis used to justify legal action)"
    "Malicious intent (systematic escalation)"
    "Aggravated damages (extended pattern, multiple crisis points)"
    "Punitive damages (manufactured crisis)"
    "Fraud indicators (crisis creation, concealment)"
    "Conspiracy (coordinated crisis escalation)"
    "Vexatious litigation (legal action based on manufactured crisis)"
  )
  
  #:escalation-visualization
  '((timeline-axis (1-mar-2025 to 11-sep-2025))
    (severity-graph (increasing-from-2 to-5))
    (crisis-events (revenue-diversion bank-letter orders-removed cards-cancelled accounts-emptied))
    (trigger-events (jax-confrontation fraud-reports-submitted))
    (legal-action (interdict-filed 13-aug-2025))
    (actor-coordination (peter danie rynette)))
  
  #:related-principles '(
    manufactured-crisis-indicators
    temporal-bad-faith-pattern-recognition-enhanced
    fraud-exposure-retaliation-indicators
    creditor-obligation-sabotage-timeline-correlation
    multi-actor-coordination-pattern-indicators
  )
  
  #:integration-points '(
    "ATTACK_HIJACKING_ANALYSIS.md"
    "ATTACK_RESOLUTION_STRATEGY.md"
    "jax-response/AD/1-Critical/PARA_10_5-10_10_23.md"
    "jax-response/AD/1-Critical/PARA_7_9-7_11.md"
  )
  
  #:test-function
  (lambda (facts)
    (let ((num-stages (assoc-ref facts 'escalation-stages-present))
          (severity-increase (assoc-ref facts 'severity-increases-each-stage))
          (peak-crisis-timing (assoc-ref facts 'peak-crisis-months-before-legal-action))
          (crisis-continues (assoc-ref facts 'crisis-continues-post-legal-action))
          (num-actors (assoc-ref facts 'number-of-coordinating-actors)))
      
      (and (>= num-stages 5)
           severity-increase
           (<= peak-crisis-timing 2)
           crisis-continues
           (>= num-actors 2)))))

