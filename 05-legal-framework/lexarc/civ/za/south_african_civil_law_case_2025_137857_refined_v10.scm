;;; WHISTLEBLOWER RETALIATION ANALYSIS - v10 NEW
;;;

(define (analyze-whistleblower-retaliation-v10 events)
  "Analyze whistleblower retaliation patterns with temporal causation"
  (let* ((whistleblowing-events (filter-whistleblowing-events events))
         (retaliation-events (filter-retaliation-events events))
         (temporal-analysis (analyze-temporal-proximity whistleblowing-events retaliation-events)))
    `(
      (whistleblowing-events . ,whistleblowing-events)
      (retaliation-events . ,retaliation-events)
      (temporal-analysis . ,temporal-analysis)
      (immediate-retaliation-confidence . ,(compute-immediate-retaliation-confidence temporal-analysis))
      (legal-protection . "Whistleblower Protection Act")
      (void-ab-initio-impact . 0.98)
    )))

(define (filter-whistleblowing-events events)
  "Filter events that constitute whistleblowing"
  (filter (lambda (event)
            (member "whistleblowing" (assoc-ref event 'legal-aspects)))
          events))

(define (filter-retaliation-events events)
  "Filter events that constitute retaliation"
  (filter (lambda (event)
            (or (member "immediate-retaliation" (assoc-ref event 'legal-aspects))
                (member "whistleblower-retaliation" (assoc-ref event 'legal-aspects))
                (member "coordinated-retaliation" (assoc-ref event 'legal-aspects))))
          events))

(define (analyze-temporal-proximity whistleblowing-events retaliation-events)
  "Analyze temporal proximity between whistleblowing and retaliation"
  (map (lambda (wb-event)
         (let* ((wb-date (car wb-event))
                (proximate-retaliations (find-proximate-events wb-date retaliation-events)))
           `(
             (whistleblowing-date . ,wb-date)
             (whistleblowing-entity . ,(assoc-ref (cdr wb-event) 'entity))
             (proximate-retaliations . ,proximate-retaliations)
             (temporal-proximity-score . ,(compute-temporal-proximity-score wb-date proximate-retaliations))
           )))
       whistleblowing-events))

(define (compute-immediate-retaliation-confidence temporal-analysis)
  "Compute confidence score for immediate retaliation (< 24 hours)"
  (let* ((immediate-retaliations (filter (lambda (analysis)
                                           (< (assoc-ref analysis 'temporal-proximity-score) 1))
                                         temporal-analysis))
         (count (length immediate-retaliations)))
    (if (> count 0) 0.98 0.0)))

