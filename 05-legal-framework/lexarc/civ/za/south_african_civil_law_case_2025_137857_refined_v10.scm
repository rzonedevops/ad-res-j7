;;;
;;; VOID AB INITIO STRENGTH CALCULATION - v10 Enhanced
;;;

(define (calculate-void-ab-initio-strength-v10 paragraph-content)
  "Calculate void ab initio strength with enhanced material omissions analysis"
  (let* ((material-omissions (identify-material-omissions-v10 paragraph-content))
         (operational-impossibility (compute-operational-impossibility-score-v10 paragraph-content))
         (regulatory-crisis (quantify-regulatory-compliance-crisis-v10 paragraph-content))
         (bad-faith-indicators (analyze-systemic-bad-faith-indicators-v10 paragraph-content))
         (settlement-trojan-horse (detect-settlement-trojan-horse-pattern paragraph-content)))
    (compute-void-strength material-omissions operational-impossibility regulatory-crisis bad-faith-indicators settlement-trojan-horse)))

(define (compute-void-strength material-omissions operational-impossibility regulatory-crisis bad-faith-indicators settlement-trojan-horse)
  "Compute overall void ab initio strength score"
  (let* ((omission-weight 0.30)
         (impossibility-weight 0.25)
         (regulatory-weight 0.20)
         (bad-faith-weight 0.15)
         (trojan-horse-weight 0.10)
         (omission-score (assoc-ref material-omissions 'severity-score))
         (impossibility-score operational-impossibility)
         (regulatory-score (assoc-ref regulatory-crisis 'severity-score))
         (bad-faith-score (assoc-ref bad-faith-indicators 'confidence))
         (trojan-horse-score (assoc-ref settlement-trojan-horse 'confidence)))
    (+ (* omission-weight omission-score)
       (* impossibility-weight impossibility-score)
       (* regulatory-weight regulatory-score)
       (* bad-faith-weight bad-faith-score)
       (* trojan-horse-weight trojan-horse-score))))

