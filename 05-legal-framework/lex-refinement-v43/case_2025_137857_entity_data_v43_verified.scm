(define (get-entity-verification-summary-v43 entity-id)
  "Get verification summary for specific entity"
  (let ((entity (find (lambda (e) (equal? (assoc-ref e 'entity-id) entity-id))
                      (get-all-verified-entities-v43))))
    (if entity
        (list
          (cons 'entity-id (assoc-ref entity 'entity-id))
          (cons 'full-name (assoc-ref entity 'full-name))
          (cons 'verification-status (assoc-ref entity 'verification-status))
          (cons 'overall-confidence (assoc-ref entity 'overall-confidence))
          (cons 'last-verified (assoc-ref entity 'last-verified)))
        '())))
