/**
 * ModelConfig.zpp - Model Configuration State and Invariants
 * Lexicog Core / Ad-Res-J7 Model Package
 * Z++ Formal Specification v1.0
 * 
 * This specification defines the model architecture configuration,
 * state invariants, and validation contracts for the lexicog model.
 */

import Types.*
import TokenizerConfig.*

// ============================================================================
// SECTION 1: MODEL CONFIGURATION STATE
// ============================================================================

/**
 * Core Model Configuration
 */
state ModelConfig {
    // Model Identity
    modelType: String,
    modelName: String,
    modelVersion: String,
    
    // Architecture Parameters
    vocabSize: VocabSize,
    hiddenSize: HiddenDim,
    intermediateSize: HiddenDim,
    numHiddenLayers: NumLayers,
    numAttentionHeads: NumHeads,
    maxPositionEmbeddings: SeqLen,
    
    // Multi-Agent Attention Configuration
    numAgentHeads: NumHeads,
    numCrossAttentionHeads: NumHeads,
    numSelfAttentionHeads: NumHeads,
    agentPoolSize: ℕ₊,
    
    // Activation and Normalization
    hiddenAct: ActivationType,
    hiddenDropoutProb: ℝ[0,1],
    attentionProbsDropoutProb: ℝ[0,1],
    layerNormEps: ℝ₊,
    
    // Embedding Configuration
    typeVocabSize: ℕ₊,
    initializerRange: ℝ₊,
    useCache: Boolean,
    
    // Legal Reasoning Configuration
    lexConfig: LexReasoningConfig,
    
    // Generation Configuration
    generationConfig: GenerationConfig,
    
    // Quantization Configuration
    quantizationConfig: Option<QuantizationConfig>,
    
    // Training Configuration
    torchDtype: DType,
    useBfloat16: Boolean
}

/**
 * Legal Reasoning Configuration
 */
state LexReasoningConfig {
    // Entity Processing
    maxEntities: ℕ₊,
    entityEmbedDim: EmbedDim,
    entityPooling: PoolingType,
    
    // Relation Processing
    maxRelations: ℕ₊,
    relationEmbedDim: EmbedDim,
    relationAttentionHeads: NumHeads,
    
    // Event/Timeline Processing
    maxEvents: ℕ₊,
    temporalEmbedDim: EmbedDim,
    temporalEncodingType: TemporalEncodingType,
    
    // Principle Processing
    maxPrinciples: ℕ₊,
    principleEmbedDim: EmbedDim,
    principleHierarchyDepth: ℕ₊,
    
    // Hypergraph Configuration
    hypergraphEnabled: Boolean,
    maxHyperedges: ℕ₊,
    hyperedgeAggregation: AggregationType,
    
    // N-Tuple Configuration
    maxTupleSize: ℕ₊,
    tupleEmbedDim: EmbedDim,
    
    // Inference Configuration
    inferenceTypes: Array<InferenceType>,
    confidenceThreshold: Confidence
}

/**
 * Generation Configuration
 */
state GenerationConfig {
    // Length Control
    maxLength: SeqLen,
    maxNewTokens: Option<SeqLen>,
    minLength: SeqLen,
    
    // Sampling Parameters
    doSample: Boolean,
    temperature: Temperature,
    topK: ℕ₊,
    topP: ℝ[0,1],
    typicalP: ℝ[0,1],
    repetitionPenalty: ℝ₊,
    
    // Beam Search
    numBeams: ℕ₊,
    numBeamGroups: ℕ₊,
    diversityPenalty: ℝ,
    lengthPenalty: ℝ,
    earlyStopping: Boolean,
    
    // Special Tokens
    padTokenId: TokenId,
    bosTokenId: TokenId,
    eosTokenId: TokenId,
    
    // Output Control
    numReturnSequences: ℕ₊,
    outputScores: Boolean,
    outputAttentions: Boolean,
    outputHiddenStates: Boolean,
    returnDictInGenerate: Boolean
}

/**
 * Quantization Configuration
 */
state QuantizationConfig {
    quantMethod: QuantizationMethod,
    bits: ℕ₊,
    groupSize: ℕ₊,
    descAct: Boolean,
    symm: Boolean
}

// ============================================================================
// SECTION 2: ENUMERATED TYPES
// ============================================================================

/**
 * Activation Function Types
 */
enum ActivationType {
    GELU,
    GELU_NEW,
    RELU,
    SILU,
    SWISH,
    TANH,
    QUICK_GELU
}

/**
 * Pooling Types
 */
enum PoolingType {
    MEAN,
    MAX,
    CLS,
    ATTENTION,
    WEIGHTED_MEAN
}

/**
 * Temporal Encoding Types
 */
enum TemporalEncodingType {
    SINUSOIDAL,
    LEARNED,
    ROTARY,
    ALIBI,
    RELATIVE
}

/**
 * Aggregation Types for Hypergraph
 */
enum AggregationType {
    SUM,
    MEAN,
    MAX,
    ATTENTION,
    GATED
}

/**
 * Data Types
 */
enum DType {
    FLOAT32,
    FLOAT16,
    BFLOAT16,
    INT8,
    INT4
}

/**
 * Quantization Methods
 */
enum QuantizationMethod {
    GPTQ,
    AWQ,
    GGUF,
    BITSANDBYTES,
    NONE
}

// ============================================================================
// SECTION 3: MODEL CONFIG INVARIANTS
// ============================================================================

/**
 * Hidden Size Divisibility
 */
invariant HiddenSizeDivisibility:
    ∀ cfg: ModelConfig •
        cfg.hiddenSize mod cfg.numAttentionHeads = 0

/**
 * Attention Head Sum
 */
invariant AttentionHeadSum:
    ∀ cfg: ModelConfig •
        cfg.numAgentHeads + cfg.numCrossAttentionHeads + cfg.numSelfAttentionHeads ≤ cfg.numAttentionHeads

/**
 * Intermediate Size Ratio
 */
invariant IntermediateSizeRatio:
    ∀ cfg: ModelConfig •
        cfg.intermediateSize ≥ cfg.hiddenSize

/**
 * Dropout Bounds
 */
invariant DropoutBounds:
    ∀ cfg: ModelConfig •
        0 ≤ cfg.hiddenDropoutProb ≤ 1 ∧
        0 ≤ cfg.attentionProbsDropoutProb ≤ 1

/**
 * Layer Norm Epsilon Positive
 */
invariant LayerNormEpsPositive:
    ∀ cfg: ModelConfig •
        cfg.layerNormEps > 0

/**
 * Vocab Size Consistency
 */
invariant VocabSizeConsistency:
    ∀ cfg: ModelConfig •
        cfg.vocabSize = TOTAL_VOCAB_SIZE

/**
 * Max Position Embeddings
 */
invariant MaxPositionEmbeddings:
    ∀ cfg: ModelConfig •
        cfg.maxPositionEmbeddings > 0

/**
 * Agent Pool Size
 */
invariant AgentPoolSize:
    ∀ cfg: ModelConfig •
        cfg.agentPoolSize ≤ MAX_ENTITIES

/**
 * Legal Config Bounds
 */
invariant LexConfigBounds:
    ∀ cfg: ModelConfig •
        cfg.lexConfig.maxEntities ≤ MAX_ENTITIES ∧
        cfg.lexConfig.maxRelations ≤ MAX_RELATIONS ∧
        cfg.lexConfig.maxEvents ≤ MAX_EVENTS ∧
        cfg.lexConfig.maxPrinciples ≤ MAX_PRINCIPLES ∧
        cfg.lexConfig.maxTupleSize ≤ MAX_TUPLE_SIZE

/**
 * Generation Config Consistency
 */
invariant GenerationConfigConsistency:
    ∀ cfg: ModelConfig •
        cfg.generationConfig.minLength ≤ cfg.generationConfig.maxLength ∧
        cfg.generationConfig.numReturnSequences ≤ cfg.generationConfig.numBeams

/**
 * Temperature Positive
 */
invariant TemperaturePositive:
    ∀ cfg: ModelConfig •
        cfg.generationConfig.temperature > 0

/**
 * Top-K Positive
 */
invariant TopKPositive:
    ∀ cfg: ModelConfig •
        cfg.generationConfig.topK > 0

/**
 * Top-P Bounds
 */
invariant TopPBounds:
    ∀ cfg: ModelConfig •
        0 < cfg.generationConfig.topP ≤ 1

// ============================================================================
// SECTION 4: DEFAULT CONFIGURATION
// ============================================================================

/**
 * Default Model Configuration
 */
