globals [current-phase total-diverted-revenue total-trust-misappropriated total-financial-loss evidence-integrity infrastructure-control-victim infrastructure-control-perp case-strength civil-threshold-met? criminal-threshold-met? interdict-granted? interdict-void? emails-sent-count ketoni-countdown days-elapsed phase-0-start phase-1-start phase-2-start phase-3-start phase-4-start phase-5-start]

breed [perpetrators perpetrator]
breed [facilitators facilitator]
breed [victims victim]
breed [corporates corporate]
breed [banks bank]
breed [regulators regulator]
breed [revenue-packets revenue-packet]
breed [email-agents email-agent]

turtles-own [agent-name agent-role financial-exposure knowledge-level]
perpetrators-own [criminal-acts-count concealment-active?]
facilitators-own [complicity-level instructions-from]
victims-own [losses-incurred awareness-level]
corporates-own [registration-number revenue-stream controlled-by]
banks-own [account-type total-flow]
regulators-own [jurisdiction investigation-active?]
revenue-packets-own [amount legitimate? destination]
email-agents-own [target-client sent?]

patches-own [zone-type financial-activity evidence-present?]

to setup
  clear-all
  set current-phase 0
  set total-diverted-revenue 0
  set total-trust-misappropriated 0
  set total-financial-loss 0
  set evidence-integrity 100
  set infrastructure-control-victim 100
  set infrastructure-control-perp 0
  set case-strength 0
  set civil-threshold-met? false
  set criminal-threshold-met? false
  set interdict-granted? false
  set interdict-void? false
  set emails-sent-count 0
  set ketoni-countdown 1157
  set days-elapsed 0
  set phase-0-start 0
  set phase-1-start 270
  set phase-2-start 690
  set phase-3-start 780
  set phase-4-start 840
  set phase-5-start 870
  setup-zones
  setup-agents
  reset-ticks
end

to setup-zones
  ;; Left = legitimate, Right = fraudulent, Center = contested, Top = regulatory
  ask patches [
    set zone-type "neutral"
    set financial-activity 0
    set evidence-present? false
    if pxcor < -10 [ set zone-type "legitimate" set pcolor 58 ]
    if pxcor > 10 [ set zone-type "fraudulent" set pcolor 18 ]
    if pxcor >= -10 and pxcor <= 10 and pycor < 10 [ set zone-type "contested" set pcolor 9.5 ]
    if pycor >= 10 [ set zone-type "regulatory" set pcolor 99 ]
  ]
end

to setup-agents
  ;; Create perpetrators
  create-perpetrators 1 [
    set agent-name "Peter Faucitt"
    set agent-role "primary-perpetrator"
    set color red
    set shape "person"
    set size 2.5
    setxy -5 -5
    set criminal-acts-count 0
    set concealment-active? false
    set financial-exposure 0
    set knowledge-level 100
  ]
  create-perpetrators 1 [
    set agent-name "Rynette Farrar"
    set agent-role "operational-controller"
    set color red + 2
    set shape "person"
    set size 2.5
    setxy 5 -5
    set criminal-acts-count 0
    set concealment-active? false
    set financial-exposure 0
    set knowledge-level 90
  ]
  ;; Create facilitators
  create-facilitators 1 [
    set agent-name "Daniel Bantjies"
    set agent-role "accountant-trustee"
    set color orange
    set shape "person"
    set size 2
    setxy 0 -10
    set complicity-level 80
    set instructions-from "Rynette Farrar"
    set financial-exposure 0
    set knowledge-level 70
  ]
  create-facilitators 2 [
    set agent-name (word "Executor-" who)
    set agent-role "email-executor"
    set color orange + 2
    set shape "person"
    set size 1.5
    setxy random-float 10 - 5 random-float 10 - 15
    set complicity-level 50
    set instructions-from "Rynette Farrar"
    set financial-exposure 0
    set knowledge-level 30
  ]
  ;; Create victims
  create-victims 1 [
    set agent-name "Daniel Faucitt"
    set agent-role "legitimate-director"
    set color green
    set shape "person"
    set size 2.5
    setxy -20 0
    set losses-incurred 0
    set awareness-level 10
    set financial-exposure 0
    set knowledge-level 50
  ]
  create-victims 1 [
    set agent-name "Jax Faucitt"
    set agent-role "victim-director"
    set color green + 2
    set shape "person"
    set size 2
    setxy -20 -10
    set losses-incurred 0
    set awareness-level 5
    set financial-exposure 0
    set knowledge-level 30
  ]
  ;; Create corporate entities
  create-corporates 1 [
    set agent-name "RWD"
    set agent-role "third-respondent"
    set color blue
    set shape "house"
    set size 2
    setxy -15 5
    set registration-number "2011/005722/07"
    set revenue-stream 3141647
    set controlled-by "Peter"
  ]
  create-corporates 1 [
    set agent-name "RegimA Zone"
    set agent-role "infrastructure-owner"
    set color blue + 2
    set shape "house"
    set size 2
    setxy -15 15
    set registration-number "UK-Company"
    set revenue-stream 8500000
    set controlled-by "Daniel"
  ]
  create-corporates 1 [
    set agent-name "FFT Trust"
    set agent-role "trust-vehicle"
    set color blue + 4
    set shape "house"
    set size 2
    setxy 0 5
    set registration-number "IT-2017"
    set revenue-stream 18750000
    set controlled-by "contested"
  ]
  ;; Create banks
  create-banks 1 [
    set agent-name "FNB"
    set agent-role "legitimate-bank"
    set color gray
    set shape "box"
    set size 3
    setxy -25 0
    set account-type "legitimate"
    set total-flow 0
  ]
  create-banks 1 [
    set agent-name "ABSA"
    set agent-role "fraudulent-destination"
    set color gray + 3
    set shape "box"
    set size 3
    setxy 25 0
    set account-type "fraudulent"
    set total-flow 0
  ]
  ;; Create regulators
  create-regulators 1 [
    set agent-name "NPA"
    set agent-role "prosecution"
    set color white
    set shape "star"
    set size 2
    setxy -10 25
    set jurisdiction "criminal"
    set investigation-active? false
  ]
  create-regulators 1 [
    set agent-name "CIPC"
    set agent-role "companies-regulator"
    set color white
    set shape "star"
    set size 2
    setxy 0 25
    set jurisdiction "corporate"
    set investigation-active? false
  ]
  create-regulators 1 [
    set agent-name "FIC"
    set agent-role "financial-intelligence"
    set color white
    set shape "star"
    set size 2
    setxy 10 25
    set jurisdiction "financial"
    set investigation-active? false
  ]
end

to go
  set days-elapsed days-elapsed + 1
  set ketoni-countdown max list 0 (1157 - days-elapsed)
  update-phase
  generate-revenue
  execute-phase-actions
  update-case-strength
  check-thresholds
  move-agents
  tick
end

to update-phase
  if days-elapsed >= phase-5-start and current-phase < 5 [
    set current-phase 5
  ]
  if days-elapsed >= phase-4-start and current-phase < 4 [
    set current-phase 4
    set interdict-granted? true
  ]
  if days-elapsed >= phase-3-start and current-phase < 3 [
    set current-phase 3
  ]
  if days-elapsed >= phase-2-start and current-phase < 2 [
    set current-phase 2
  ]
  if days-elapsed >= phase-1-start and current-phase < 1 [
    set current-phase 1
  ]
end

to generate-revenue
  ;; Generate revenue packets flowing through the system
  if random 100 < revenue-generation-rate [
    create-revenue-packets 1 [
      set shape "circle"
      set size 1
      setxy -28 random-float 10 - 5
      set amount (8500000 / 365) * (1 + random-float 0.3 - 0.15)
      set legitimate? true
      set destination "FNB"
      set color yellow
    ]
  ]
end

to execute-phase-actions
  ;; Phase-specific fraud actions
  if current-phase >= 2 [
    ;; Infrastructure seizure
    if infrastructure-control-victim > 0 [
      set infrastructure-control-victim max list 0 (infrastructure-control-victim - seizure-rate / 30)
      set infrastructure-control-perp min list 100 (infrastructure-control-perp + seizure-rate / 30)
    ]
  ]
  if current-phase >= 3 [
    ;; Revenue diversion - redirect packets
    ask revenue-packets with [legitimate? and xcor > -10] [
      if random 100 < diversion-rate [
        set legitimate? false
        set destination "ABSA"
        set color red
        set heading 90
      ]
    ]
    ;; Send banking detail change emails
    if emails-sent-count < 100 and random 100 < email-campaign-speed [
      create-email-agents 1 [
        set shape "arrow"
        set size 1
        set color cyan
        setxy 0 random-float 20 - 10
        set heading 90
        set target-client (word "Client-" emails-sent-count)
        set sent? true
      ]
      set emails-sent-count emails-sent-count + 1
    ]
  ]
  if current-phase >= 4 [
    ;; Trust misappropriation
    let trust-extract trust-extraction-rate * 18750000 / 365 / 100
    set total-trust-misappropriated total-trust-misappropriated + trust-extract
  ]
  if current-phase >= 5 and evidence-destruction? [
    ;; Evidence destruction
    set evidence-integrity max list 0 (evidence-integrity - destruction-rate / 30)
    ask patches with [evidence-present?] [
      if random 100 < 2 [
        set evidence-present? false
        set pcolor pcolor - 0.5
      ]
    ]
  ]
end

to update-case-strength
  ;; Calculate prosecution case strength based on evidence
  let revenue-weight (total-diverted-revenue / 10269728) * 40
  let infra-weight (infrastructure-control-perp / 100) * 30
  let evidence-weight ((100 - evidence-integrity) / 100) * 15 + 15
  set case-strength min list 100 (revenue-weight + infra-weight + evidence-weight)
  set total-financial-loss total-diverted-revenue + total-trust-misappropriated
end

to check-thresholds
  ;; Check burden of proof thresholds
  if case-strength >= 50 and not civil-threshold-met? [
    set civil-threshold-met? true
    ask regulators [ set investigation-active? true ]
  ]
  if case-strength >= 95 and not criminal-threshold-met? [
    set criminal-threshold-met? true
    set interdict-void? true
  ]
end

to move-agents
  ;; Move revenue packets toward destination
  ask revenue-packets [
    ifelse legitimate? [
      set heading towards one-of banks with [agent-name = "FNB"]
      fd 0.5
      if xcor < -23 [
        ask one-of banks with [agent-name = "FNB"] [ set total-flow total-flow + [amount] of myself ]
        die
      ]
    ] [
      set heading towards one-of banks with [agent-name = "ABSA"]
      fd 0.8
      if xcor > 23 [
        set total-diverted-revenue total-diverted-revenue + amount
        ask one-of banks with [agent-name = "ABSA"] [ set total-flow total-flow + [amount] of myself ]
        die
      ]
    ]
  ]
  ;; Move email agents
  ask email-agents [
    fd 0.3
    if xcor > 28 or ycor > 28 or xcor < -28 or ycor < -28 [ die ]
  ]
  ;; Perpetrator movement based on phase
  ask perpetrators [
    if current-phase >= 3 [ set heading towards one-of banks with [agent-name = "ABSA"] fd 0.1 ]
    set criminal-acts-count criminal-acts-count + (ifelse-value (current-phase >= 3) [1] [0])
  ]
  ;; Victim awareness increases over time
  ask victims [
    if current-phase >= 3 [
      set awareness-level min list 100 (awareness-level + 0.1)
      set losses-incurred total-diverted-revenue / 2
    ]
  ]
end

to-report phase-label
  report ifelse-value current-phase = 0 ["0: Investment"]
  [ifelse-value current-phase = 1 ["1: Creditor Elimination"]
    [ifelse-value current-phase = 2 ["2: Infrastructure Seizure"]
      [ifelse-value current-phase = 3 ["3: Revenue Hijacking"]
        [ifelse-value current-phase = 4 ["4: Legal Weaponization"]
          ["5: Evidence Destruction"]]]]]
end

to-report total-loss-millions
  report total-financial-loss / 1000000
end

to-report diverted-millions
  report total-diverted-revenue / 1000000
end

to-report trust-millions
  report total-trust-misappropriated / 1000000
end

