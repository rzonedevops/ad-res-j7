@#$#@#$#@
NetLogo 6.4.0
@#$#@#$#@
setup
repeat 50 [ go ]
@#$#@#$#@

@#$#@#$#@
<experiments>
  <experiment name="baseline-scenario" repetitions="10" runMetricsEveryStep="true">
    <setup>setup</setup>
    <go>go</go>
    <timeLimit steps="1100"/>
    <metric>total-financial-loss</metric>
    <metric>case-strength</metric>
    <metric>evidence-integrity</metric>
    <metric>emails-sent-count</metric>
    <metric>current-phase</metric>
  </experiment>
  <experiment name="early-detection-scenario" repetitions="10" runMetricsEveryStep="true">
    <setup>set scenario "early-detection" setup</setup>
    <go>go</go>
    <timeLimit steps="1100"/>
    <metric>total-financial-loss</metric>
    <metric>case-strength</metric>
    <metric>evidence-integrity</metric>
  </experiment>
  <experiment name="sensitivity-diversion-rate" repetitions="5" runMetricsEveryStep="true">
    <setup>setup</setup>
    <go>go</go>
    <timeLimit steps="1100"/>
    <metric>total-financial-loss</metric>
    <metric>case-strength</metric>
  </experiment>
</experiments>
@#$#@#$#@

