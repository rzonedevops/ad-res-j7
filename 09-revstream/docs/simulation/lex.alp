<AnyLogicWorkspace WorkspaceVersion="1.9" AnyLogicVersion="8.6.0.202004061611" AlpVersion="8.5.7">
<Model>
	<Id>1773111131532</Id>
	<Name><![CDATA[LEX_Legal_Reasoning_Framework]]></Name>
	<Description><![CDATA[Multi-paradigm simulation of the LEX Legal Reasoning Framework from ad-res-j7/lex. Models the complete legal analysis pipeline: evidence intake, modal logic qualification (alethic/deontic/epistemic), 7-lens attention scoring (Fiduciary, Causation, Necessity, Proportionality, Procedural, Temporal, Evidentiary), inference engine (deductive/inductive/abductive/analogical), burden of proof assessment, grip optimization, and outcome prediction. System Dynamics models knowledge accumulation across 15 legal domains. Discrete-Event Simulation models evidence processing through the analysis pipeline. Agent-Based Modeling represents the 128 legal reasoning skills and their 4-layer composition architecture.]]></Description>
	<EngineVersion>6</EngineVersion>
	<JavaPackageName><![CDATA[lex_framework]]></JavaPackageName>
	<ModelTimeUnit><![CDATA[Minute]]></ModelTimeUnit>
