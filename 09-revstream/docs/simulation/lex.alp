			<Functions>
				<Function>
					<Id>1773111131723</Id>
					<Name><![CDATA[calculateGripScore]]></Name>
					<X>50</X><Y>400</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties ReturnType="double">
						<Body><![CDATA[return (GripScore_Relevance + GripScore_Coherence + GripScore_Completeness + GripScore_Confidence + GripScore_Coverage + GripScore_Salience + GripScore_Temporal + GripScore_Causal) / 8.0;]]></Body>
					</Properties>
				</Function>
				<Function>
					<Id>1773111131724</Id>
					<Name><![CDATA[getModalOperatorLabel]]></Name>
					<X>50</X><Y>400</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties ReturnType="String">
						<Body><![CDATA[switch(currentModalOperator) {
  case 0: return "Alethic (necessary/possible/contingent)";
  case 1: return "Deontic (obligatory/permitted/forbidden)";
  case 2: return "Epistemic (known/believed/unknown)";
  default: return "Unknown";
}]]></Body>
					</Properties>
				</Function>
				<Function>
					<Id>1773111131725</Id>
					<Name><![CDATA[getInferenceModeLabel]]></Name>
					<X>50</X><Y>400</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties ReturnType="String">
						<Body><![CDATA[switch(currentInferenceMode) {
  case 0: return "Deductive";
  case 1: return "Inductive";
  case 2: return "Abductive";
  case 3: return "Analogical";
  default: return "Unknown";
}]]></Body>
					</Properties>
				</Function>
				<Function>
					<Id>1773111131726</Id>
					<Name><![CDATA[getLensScoreVector]]></Name>
					<X>50</X><Y>400</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties ReturnType="String">
						<Body><![CDATA[return String.format("F:%.2f C:%.2f N:%.2f P:%.2f Pr:%.2f T:%.2f E:%.2f", fiduciaryScore, causationScore, necessityScore, proportionalityScore, proceduralScore, temporalScore, evidentiaryScore);]]></Body>
					</Properties>
				</Function>
				<Function>
					<Id>1773111131727</Id>
					<Name><![CDATA[getPipelineStageLabel]]></Name>
					<X>50</X><Y>400</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties ReturnType="String">
						<Body><![CDATA[switch(pipelineStage) {
  case 0: return "Idle";
  case 1: return "Evidence Intake";
  case 2: return "Modal Qualification";
  case 3: return "Attention Scoring";
  case 4: return "Inference Reasoning";
  case 5: return "Burden Assessment";
  case 6: return "Grip Optimization";
  case 7: return "Outcome Prediction";
  default: return "Unknown";
}]]></Body>
					</Properties>
				</Function>
			</Functions>
