{
  "name": "LEX_DigiTwin_2025-137857",
  "description": "Legal Digital Twin for Revenue Stream Hijacking",
  "package_name": "lex_digitwin",
  "time_unit": "Month",
  "final_time": 54.0,
  "paradigms": [
    "SD",
    "DES",
    "ABM"
  ],
  "variables": [
    {
      "class": "StockVariable",
      "name": "legitimate_revenue",
      "initial_value": "5000000",
      "x": 100,
      "y": 100
    },
    {
      "class": "StockVariable",
      "name": "diverted_revenue",
      "initial_value": "0",
      "x": 300,
      "y": 100
    },
    {
      "class": "StockVariable",
      "name": "legal_exposure",
      "initial_value": "0",
      "x": 500,
      "y": 100
    },
    {
      "class": "StockVariable",
      "name": "evidence_strength",
      "initial_value": "0",
      "x": 700,
      "y": 100
    },
    {
      "class": "Flow",
      "name": "diversion_flow",
      "formula": "diversion_rate * legitimate_revenue",
      "source_name": "legitimate_revenue",
      "target_name": "diverted_revenue",
      "x": 200,
      "y": 100
    },
    {
      "class": "AuxVariable",
      "name": "diversion_rate",
      "formula": "0.15",
      "x": 200,
      "y": 200
    }
  ],
  "flowchart_blocks": [
    {
      "class": "Source",
      "name": "transactions",
      "params": {
        "rate": {
          "code": "50",
          "unit_class": "RateUnits",
          "unit": "PER_MONTH"
        }
      },
      "x": 50,
      "y": 350
    },
    {
      "class": "SelectOutput",
      "name": "fraud_check",
      "params": {
        "condition": "uniform() < diversion_rate"
      },
      "x": 200,
      "y": 350
    },
    {
      "class": "Queue",
      "name": "legitimate_queue",
      "params": {
        "capacity": "1000"
      },
      "x": 350,
      "y": 300
    },
    {
      "class": "Queue",
      "name": "diverted_queue",
      "params": {
        "capacity": "1000"
      },
      "x": 350,
      "y": 400
    },
    {
      "class": "Sink",
      "name": "legitimate_sink",
      "x": 500,
      "y": 300
    },
    {
      "class": "Sink",
      "name": "diverted_sink",
      "x": 500,
      "y": 400
    }
  ],
  "connections": [
    {
      "from": "transactions",
      "to": "fraud_check"
    },
    {
      "from": "fraud_check",
      "to": "legitimate_queue"
    },
    {
      "from": "fraud_check",
      "to": "diverted_queue"
    },
    {
      "from": "legitimate_queue",
      "to": "legitimate_sink"
    },
    {
      "from": "diverted_queue",
      "to": "diverted_sink"
    }
  ],
