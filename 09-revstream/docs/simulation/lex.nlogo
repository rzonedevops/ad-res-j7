<experiments>
  <experiment name="baseline-lex-pipeline" repetitions="10" runMetricsEveryStep="true">
    <setup>setup</setup>
    <go>go</go>
    <timeLimit steps="500"/>
    <metric>civil-case-strength</metric>
    <metric>criminal-case-strength</metric>
    <metric>overall-grip-score</metric>
    <metric>justice-delta</metric>
    <metric>active-skills-count</metric>
    <metric>total-claims-validated</metric>
  </experiment>
  <experiment name="high-evidence-throughput" repetitions="10" runMetricsEveryStep="true">
    <setup>set evidence-arrival-rate 80 setup</setup>
    <go>go</go>
    <timeLimit steps="300"/>
    <metric>civil-case-strength</metric>
    <metric>criminal-case-strength</metric>
    <metric>total-claims-validated</metric>
    <metric>pipeline-throughput</metric>
  </experiment>
  <experiment name="sensitivity-evidence-weight" repetitions="5" runMetricsEveryStep="true">
    <setup>setup</setup>
    <go>go</go>
    <timeLimit steps="500"/>
    <metric>civil-case-strength</metric>
    <metric>criminal-case-strength</metric>
    <metric>overall-grip-score</metric>
  </experiment>
</experiments>
