; LEX_Legal_Reasoning_Framework
; Generated by nlogo-multi-method skill

globals [pipeline-stage total-evidence-processed total-propositions-qualified total-attention-scored total-inferences-made total-claims-validated civil-case-strength criminal-case-strength grip-relevance grip-coherence grip-completeness grip-confidence grip-coverage grip-salience grip-temporal grip-causal overall-grip-score justice-delta active-skills-count knowledge-principles knowledge-rules knowledge-relationships hypergraph-density civil-threshold-met? criminal-threshold-met? ticks-per-minute]

breed [evidence-items evidence-item]
breed [legal-principles legal-principle]
breed [attention-lenses attention-lens]
breed [inference-engines inference-engine]
breed [skill-agents skill-agent]
breed [domain-agents domain-agent]
breed [claim-tokens claim-token]
breed [grip-nodes grip-node]

turtles-own [agent-label processing-time confidence-score]
evidence-items-own [evidence-type modal-operator attention-vector inference-mode qualified? scored? inferred? validated?]
legal-principles-own [principle-domain principle-level activation-strength connected-rules]
attention-lenses-own [lens-type lens-score lens-weight]
inference-engines-own [inference-type throughput accuracy]
skill-agents-own [skill-domain skill-layer skill-active? proficiency]
domain-agents-own [domain-name domain-coverage rule-count]
claim-tokens-own [claim-type claim-strength burden-met?]
grip-nodes-own [grip-dimension grip-value target-value]

patches-own [zone-type activity-level evidence-present?]

to setup
  clear-all
  set pipeline-stage 0
  set total-evidence-processed 0
  set total-propositions-qualified 0
  set total-attention-scored 0
  set total-inferences-made 0
  set total-claims-validated 0
  set civil-case-strength 0
  set criminal-case-strength 0
  set grip-relevance 0
  set grip-coherence 0
  set grip-completeness 0
  set grip-confidence 0
  set grip-coverage 0
  set grip-salience 0
  set grip-temporal 0
  set grip-causal 0
  set overall-grip-score 0
  set justice-delta 100
  set active-skills-count 0
  set knowledge-principles 63
  set knowledge-rules 312
  set knowledge-relationships 250
  set hypergraph-density (knowledge-principles + knowledge-rules + knowledge-relationships) / 625
  set civil-threshold-met? false
  set criminal-threshold-met? false
  set ticks-per-minute 1
  setup-zones
  setup-knowledge-base
  setup-attention-lenses
  setup-inference-engines
  setup-skill-agents
  setup-domain-agents
  setup-grip-nodes
  reset-ticks
end

to setup-zones
  ;; Zone layout: Left=Intake, Center-Left=Modal, Center=Attention, Center-Right=Inference, Right=Output
  ask patches [
    set zone-type "neutral"
    set activity-level 0
    set evidence-present? false
    ;; Intake zone (far left)
    if pxcor < -20 [ set pcolor 57 set zone-type "intake" ]
    ;; Modal qualification zone
    if pxcor >= -20 and pxcor < -10 [ set pcolor 97 set zone-type "modal" ]
    ;; Attention scoring zone (center)
    if pxcor >= -10 and pxcor < 0 [ set pcolor 47 set zone-type "attention" ]
    ;; Inference zone
    if pxcor >= 0 and pxcor < 10 [ set pcolor 117 set zone-type "inference" ]
    ;; Burden/Grip zone
    if pxcor >= 10 and pxcor < 20 [ set pcolor 27 set zone-type "burden" ]
    ;; Output/Justice zone (far right)
    if pxcor >= 20 [ set pcolor 67 set zone-type "output" ]
    ;; Knowledge base (top)
    if pycor > 20 [ set pcolor 9.5 set zone-type "knowledge" ]
    ;; Skills layer (bottom)
    if pycor < -20 [ set pcolor 5 set zone-type "skills" ]
  ]
end

to setup-knowledge-base
  ;; Create 63 Level 1 principles
  let principle-domains (list "civil" "criminal" "evidence" "company" "trust" "data-protection" "forensic" "admin" "constitutional" "ethics" "environmental" "international" "labour" "prof-ethics" "civil-proc")
  create-legal-principles 63 [
    set shape "circle"
    set color white
    set size 0.8
    set principle-level 1
    set activation-strength 0
    set connected-rules random 10 + 1
    set principle-domain one-of principle-domains
    setxy (random-float 50 - 25) (random-float 8 + 22)
    set agent-label (word "P" who)
  ]
end

to setup-attention-lenses
  ;; Create 7 attention lenses
  let lens-types (list "Fiduciary" "Causation" "Necessity" "Proportionality" "Procedural" "Temporal" "Evidentiary")
  let lens-colors (list 15 25 45 55 85 105 125)
  let lens-weights (list 0.15 0.15 0.1 0.1 0.15 0.15 0.2)
  let i 0
  while [i < 7] [
    create-attention-lenses 1 [
      set shape "star"
      set size 1.5
      set color item i lens-colors
      set lens-type item i lens-types
      set lens-score 0
      set lens-weight item i lens-weights
      setxy (-5 + i * 1.5 - 5) 15
      set agent-label lens-type
      set label lens-type
      set label-color black
    ]
    set i i + 1
  ]
end

to setup-inference-engines
  ;; Create 4 inference engines
  let inf-types (list "Deductive" "Inductive" "Abductive" "Analogical")
  let inf-colors (list 15 55 95 125)
  let j 0
  while [j < 4] [
    create-inference-engines 1 [
      set shape "triangle"
      set size 1.5
      set color item j inf-colors
      set inference-type item j inf-types
      set throughput 0
      set accuracy 0.7 + random-float 0.3
      setxy (3 + j * 2) 15
      set agent-label inference-type
      set label inference-type
      set label-color black
    ]
    set j j + 1
  ]
end

to setup-skill-agents
  ;; Create 128 legal reasoning skills across 4 layers
  let skill-domains (list "civ" "cri" "evid" "cmp" "trs" "dat" "frn" "adm" "cst")
  create-skill-agents 128 [
    set shape "square"
    set size 0.6
    set color gray
    set skill-domain one-of skill-domains
    set skill-layer (random 4) + 1
    set skill-active? false
    set proficiency 0
    setxy (random-float 50 - 25) (random-float 8 - 28)
    set agent-label (word "S" who)
  ]
end

to setup-domain-agents
  ;; Create 15 legal domain agents
  let domain-names (list "Civil" "Criminal" "Evidence" "Company" "Trust" "DataProt" "Forensic" "Admin" "Const" "Ethics" "Environ" "Intl" "Labour" "ProfEth" "CivProc")
  let domain-rules (list 20 18 18 20 18 18 18 8 8 8 8 8 8 8 8)
  let k 0
  while [k < 15] [
    create-domain-agents 1 [
      set shape "pentagon"
      set size 1.2
      set color 45 + k * 8
      set domain-name item k domain-names
      set domain-coverage 0
      set rule-count item k domain-rules
      setxy (-28 + k * 4) -15
      set agent-label domain-name
      set label domain-name
      set label-color black
    ]
    set k k + 1
  ]
end

to setup-grip-nodes
  ;; Create 8 grip dimension nodes
  let grip-dims (list "Relevance" "Coherence" "Completeness" "Confidence" "Coverage" "Salience" "Temporal" "Causal")
  let m 0
  while [m < 8] [
    create-grip-nodes 1 [
      set shape "diamond"
      set size 1.2
      set color 15 + m * 14
      set grip-dimension item m grip-dims
      set grip-value 0
      set target-value 100
      setxy (13 + (m mod 4) * 4) (-5 + floor (m / 4) * 4)
      set agent-label grip-dimension
      set label grip-dimension
      set label-color black
    ]
    set m m + 1
  ]
end

to go
  generate-evidence
  process-modal-qualification
  process-attention-scoring
  process-inference
  process-burden-assessment
  update-grip-scores
  update-skills
  update-justice-delta
  check-thresholds
  tick
end

to generate-evidence
  ;; Generate new evidence items at the configured rate
  if random-float 1.0 < evidence-arrival-rate / 100 [
    create-evidence-items 1 [
      set shape "dot"
      set size 1.0
      set color yellow
      set evidence-type one-of (list "documentary" "testimonial" "circumstantial" "expert" "admission")
      set modal-operator ""
      set attention-vector (list 0 0 0 0 0 0 0)
      set inference-mode ""
      set qualified? false
      set scored? false
      set inferred? false
      set validated? false
      set confidence-score random-float 1.0
      setxy (-25 + random-float 4) (random-float 30 - 15)
      set total-evidence-processed total-evidence-processed + 1
    ]
  ]
end

to process-modal-qualification
  ;; Move unqualified evidence to modal zone and qualify
  ask evidence-items with [not qualified?] [
    ;; Move toward modal zone
    if pxcor < -15 [
      set heading 90
      fd 0.5
    ]
    ;; Qualify when in modal zone
    if pxcor >= -20 and pxcor < -10 [
      let operator-roll random 3
      if operator-roll = 0 [ set modal-operator "alethic" set color 97 ]
      if operator-roll = 1 [ set modal-operator "deontic" set color 87 ]
      if operator-roll = 2 [ set modal-operator "epistemic" set color 107 ]
      set qualified? true
      set total-propositions-qualified total-propositions-qualified + 1
      set processing-time 2 + random 3
    ]
  ]
end

to process-attention-scoring
  ;; Score qualified evidence through 7 lenses
  ask evidence-items with [qualified? and not scored?] [
    if processing-time > 0 [
      set processing-time processing-time - 1
    ]
    if processing-time <= 0 [
      ;; Move toward attention zone
      if pxcor < -5 [
        set heading 90
        fd 0.5
      ]
      if pxcor >= -10 and pxcor < 0 [
        ;; Score through each lens
        set attention-vector (list
          (random-float 0.7 + 0.3)   ;; Fiduciary
          (random-float 0.8 + 0.2)   ;; Causation
          (random-float 0.6 + 0.1)   ;; Necessity
          (random-float 0.6 + 0.2)   ;; Proportionality
          (random-float 0.7 + 0.3)   ;; Procedural
          (random-float 0.6 + 0.4)   ;; Temporal
          (random-float 0.5 + 0.5)   ;; Evidentiary
        )
        set scored? true
        set total-attention-scored total-attention-scored + 1
        set color scale-color green (mean attention-vector) 0 1.5
        set processing-time 5 + random 8
        ;; Update lens scores
        ask attention-lenses [
          let idx position lens-type (list "Fiduciary" "Causation" "Necessity" "Proportionality" "Procedural" "Temporal" "Evidentiary")
          if idx != false [
            set lens-score lens-score + item idx [attention-vector] of myself
          ]
        ]
      ]
    ]
  ]
end

to process-inference
  ;; Apply inference reasoning to scored evidence
  ask evidence-items with [scored? and not inferred?] [
    if processing-time > 0 [
      set processing-time processing-time - 1
    ]
    if processing-time <= 0 [
      ;; Move toward inference zone
      if pxcor < 5 [
        set heading 90
        fd 0.5
      ]
      if pxcor >= 0 and pxcor < 10 [
        let mode-roll random 4
        if mode-roll = 0 [ set inference-mode "deductive" set color 15 ]
        if mode-roll = 1 [ set inference-mode "inductive" set color 55 ]
        if mode-roll = 2 [ set inference-mode "abductive" set color 95 ]
        if mode-roll = 3 [ set inference-mode "analogical" set color 125 ]
        set inferred? true
        set total-inferences-made total-inferences-made + 1
        set processing-time 10 + random 5
        ;; Activate relevant principles
        ask n-of (min (list 3 count legal-principles)) legal-principles [
          set activation-strength min (list 1.0 (activation-strength + 0.1))
          set color scale-color yellow activation-strength 0 1.5
        ]
      ]
    ]
  ]
end

to process-burden-assessment
  ;; Assess burden of proof for inferred evidence
  ask evidence-items with [inferred? and not validated?] [
    if processing-time > 0 [
      set processing-time processing-time - 1
    ]
    if processing-time <= 0 [
      ;; Move toward burden zone
      if pxcor < 15 [
        set heading 90
        fd 0.5
      ]
      if pxcor >= 10 and pxcor < 20 [
        set validated? true
        set total-claims-validated total-claims-validated + 1
        ;; Update case strengths
        let evidence-weight mean attention-vector * confidence-score
        set civil-case-strength min (list 100 (civil-case-strength + evidence-weight * civil-weight-factor))
        set criminal-case-strength min (list 100 (criminal-case-strength + evidence-weight * criminal-weight-factor * 0.6))
        ;; Create claim token
        hatch-claim-tokens 1 [
          set shape "arrow"
          set size 0.8
          set claim-type one-of (list "civil" "criminal" "regulatory")
          set claim-strength evidence-weight
          set burden-met? (claim-strength > 0.5)
          set color ifelse-value burden-met? [green] [red]
        ]
        ;; Move to output zone
        set heading 90
        fd 3
        set color blue
      ]
    ]
  ]
end

to update-grip-scores
  ;; Update 8 grip dimensions based on pipeline state
  if total-claims-validated > 0 [
    let fiduciary-avg ifelse-value (any? attention-lenses with [lens-type = "Fiduciary"]) [mean [lens-score] of attention-lenses with [lens-type = "Fiduciary"]] [0]
    let causation-avg ifelse-value (any? attention-lenses with [lens-type = "Causation"]) [mean [lens-score] of attention-lenses with [lens-type = "Causation"]] [0]
    let evidentiary-avg ifelse-value (any? attention-lenses with [lens-type = "Evidentiary"]) [mean [lens-score] of attention-lenses with [lens-type = "Evidentiary"]] [0]
    set grip-relevance min (list 100 ((fiduciary-avg * 0.2 + causation-avg * 0.2 + evidentiary-avg * 0.6) / max (list 1 total-attention-scored) * 100))
    set grip-coherence min (list 100 (total-inferences-made / max (list 1 total-attention-scored) * 100))
    set grip-completeness min (list 100 (active-skills-count / 128 * 100))
    set grip-confidence min (list 100 (civil-case-strength * 0.6 + criminal-case-strength * 0.4))
    set grip-coverage min (list 100 (count domain-agents with [domain-coverage > 0] / 15 * 100))
    set grip-salience min (list 100 (total-claims-validated / max (list 1 total-evidence-processed) * 100))
    set grip-temporal min (list 100 (ticks / 100 * 10))
    set grip-causal min (list 100 (total-inferences-made / max (list 1 total-evidence-processed) * 80))
    set overall-grip-score (grip-relevance + grip-coherence + grip-completeness + grip-confidence + grip-coverage + grip-salience + grip-temporal + grip-causal) / 8
    ;; Update grip node visuals
    ask grip-nodes [
      if grip-dimension = "Relevance" [ set grip-value grip-relevance ]
      if grip-dimension = "Coherence" [ set grip-value grip-coherence ]
      if grip-dimension = "Completeness" [ set grip-value grip-completeness ]
      if grip-dimension = "Confidence" [ set grip-value grip-confidence ]
      if grip-dimension = "Coverage" [ set grip-value grip-coverage ]
      if grip-dimension = "Salience" [ set grip-value grip-salience ]
      if grip-dimension = "Temporal" [ set grip-value grip-temporal ]
      if grip-dimension = "Causal" [ set grip-value grip-causal ]
      set size 0.5 + grip-value / 50
    ]
  ]
end

to update-skills
  ;; Activate skills based on validated claims
  if total-claims-validated > 0 [
    let skills-to-activate min (list skill-activation-rate (count skill-agents with [not skill-active?]))
    ask n-of skills-to-activate skill-agents with [not skill-active?] [
      set skill-active? true
      set proficiency random-float 0.5 + 0.5
      set color scale-color cyan proficiency 0 1.5
      set active-skills-count active-skills-count + 1
    ]
    ;; Update domain coverage
    ask domain-agents [
      let my-domain domain-name
      let matching-skills count skill-agents with [skill-active? and skill-domain = (substring my-domain 0 min (list 3 length my-domain))]
      set domain-coverage min (list 100 (matching-skills / max (list 1 rule-count) * 100))
      set size 0.8 + domain-coverage / 100
    ]
  ]
end

to update-justice-delta
  ;; Converge justice delta toward zero as case strengthens
  if civil-case-strength > 50 [
    set justice-delta max (list 0 (justice-delta - justice-convergence-rate * (civil-case-strength / 100)))
  ]
  ;; Remove old validated evidence that reached output zone
  ask evidence-items with [validated? and pxcor > 25] [
    die
  ]
  ;; Remove old claim tokens
  ask claim-tokens with [ticks - processing-time > 100] [
    die
  ]
end

to check-thresholds
  ;; Check burden of proof thresholds
  if civil-case-strength >= 50 and not civil-threshold-met? [
    set civil-threshold-met? true
    output-print (word "CIVIL THRESHOLD (50%) exceeded at tick " ticks)
  ]
  if criminal-case-strength >= 95 and not criminal-threshold-met? [
    set criminal-threshold-met? true
    output-print (word "CRIMINAL THRESHOLD (95%) exceeded at tick " ticks)
  ]
  if active-skills-count >= 128 [
    output-print (word "All 128 legal reasoning skills activated at tick " ticks)
  ]
  if overall-grip-score >= 90 [
    output-print (word "Full grip (90%+) achieved at tick " ticks)
  ]
  if justice-delta <= 5 [
    output-print (word "Justice delta converged at tick " ticks)
  ]
end

to-report pipeline-throughput
  report ifelse-value (ticks > 0) [total-claims-validated / ticks * 100] [0]
end

to-report evidence-in-pipeline
  report count evidence-items
end

to-report active-principles
  report count legal-principles with [activation-strength > 0]
end

to-report modal-operator-label
  report ifelse-value (any? evidence-items with [qualified? and not scored?]) [(word "Processing: " [modal-operator] of one-of evidence-items with [qualified? and not scored?])] ["Idle"]
end

