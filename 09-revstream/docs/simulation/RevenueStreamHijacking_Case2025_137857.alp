			<Functions>
				<Function>
					<Id>1773105644627</Id>
					<Name><![CDATA[calculateBurdenOfProof]]></Name>
					<X>50</X><Y>400</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties ReturnType="double">
						<Body><![CDATA[double evidenceWeight = (DivertedRevenue_ABSA / 10269728.0) * 40;
double infraWeight = (InfrastructureControl_Perp / 100.0) * 30;
double destructionWeight = ((100 - EvidenceIntegrity) / 100.0) * 30;
return Math.min(100, evidenceWeight + infraWeight + destructionWeight);]]></Body>
					</Properties>
				</Function>
				<Function>
					<Id>1773105644628</Id>
					<Name><![CDATA[getPhaseLabel]]></Name>
					<X>50</X><Y>400</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties ReturnType="String">
						<Body><![CDATA[switch(currentPhase) {
  case 0: return "Investment";
  case 1: return "Creditor Elimination";
  case 2: return "Infrastructure Seizure";
  case 3: return "Revenue Hijacking";
  case 4: return "Legal Weaponization";
  case 5: return "Evidence Destruction";
  default: return "Unknown";
}]]></Body>
					</Properties>
				</Function>
				<Function>
					<Id>1773105644629</Id>
					<Name><![CDATA[getFinancialImpactSummary]]></Name>
					<X>50</X><Y>400</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties ReturnType="String">
						<Body><![CDATA[return String.format("Revenue Theft: R%.2f | Trust Violations: R%.2f | Total: R%.2f", DivertedRevenue_ABSA, MisappropriatedTrustFunds, TotalFinancialLoss);]]></Body>
					</Properties>
				</Function>
			</Functions>
