{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cogpy.github.io/revstream1/contracts/timeline_schema.json",
  "title": "Timeline Model Schema",
  "description": "JSON Schema for Revenue Stream Hijacking case timeline data model.",
  "type": "object",
  "required": ["metadata", "timeline"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["version", "case_number", "total_entries"],
      "properties": {
        "version": { "type": "string" },
        "created_date": { "type": "string" },
        "description": { "type": "string" },
        "case_number": { "type": "string" },
        "last_updated": { "type": "string" },
        "changes": { "type": "string" },
        "total_entries": { "type": "integer", "minimum": 0 },
        "total_events": { "type": "integer", "minimum": 0 },
        "criminal_threshold_entries": { "type": "integer", "minimum": 0 },
        "high_significance_entries": { "type": "integer", "minimum": 0 },
        "civil_threshold_entries": { "type": "integer", "minimum": 0 },
        "completeness_audit": { "type": "string" },
        "by_year": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        }
      }
    },
    "timeline": {
      "type": "array",
      "items": { "$ref": "#/$defs/timeline_entry" }
    }
  },
  "$defs": {
    "timeline_entry": {
      "type": "object",
      "required": ["date"],
      "anyOf": [
        { "required": ["event"] },
        { "required": ["title"] },
        { "required": ["description"] }
      ],
      "properties": {
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}"
        },
        "event": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "entity": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "source": { "type": "string" },
        "category": { "type": "string" },
        "significance_level": { "type": "string" },
        "entry_id": { "type": "string" },
        "event_type": { "type": "string" },
        "significance": { "type": "string" },
        "burden_of_proof": { "type": "string" },
        "added_date": { "type": "string" },
        "merged_from": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "key_actor_names": {
          "type": "array",
          "items": { "type": "string" }
        },
        "key_actors": {
          "type": "array"
        },
        "entities_involved": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ad_res_j7_evidence_enhanced": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_enhanced_timestamp": { "type": "string" },
        "burden_of_proof_verified": { "type": "string" },
        "event_ref": { "type": "string" },
        "actors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
