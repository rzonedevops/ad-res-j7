{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cogpy.github.io/revstream1/contracts/event_schema.json",
  "title": "Event Model Schema",
  "description": "JSON Schema for Revenue Stream Hijacking case event data model. Validates the canonical event format consumed by LexRexHGNN and ad-res-j7.",
  "type": "object",
  "required": ["metadata", "events"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["version", "case_number", "total_events"],
      "properties": {
        "version": { "type": "string" },
        "created_date": { "type": "string" },
        "description": { "type": "string" },
        "case_number": { "type": "string" },
        "total_events": { "type": "integer", "minimum": 0 },
        "last_updated": { "type": "string" },
        "changes": { "type": "string" },
        "extended_evidence": { "type": "string" },
        "phase_statistics": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "criminal_threshold_events": { "type": "integer", "minimum": 0 },
        "civil_threshold_events": { "type": "integer", "minimum": 0 }
      }
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event" }
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "required": ["event_id", "date"],
      "properties": {
        "event_id": { "type": "string" },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}"
        },
        "title": { "type": "string" },
        "event_type": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string", "minLength": 1 },
        "entities_involved": {
          "type": "array",
          "items": { "type": "string" }
        },
        "perpetrators": {
          "type": "array",
          "items": { "type": "string" }
        },
        "victims": {
          "type": "array",
          "items": { "type": "string" }
        },
        "location": { "type": "string" },
        "financial_impact": {},
        "significance": { "type": "string" },
        "legal_significance": { "type": "string" },
        "evidence": {
          "oneOf": [
            { "type": "array", "items": { "type": "string" } },
            { "type": "object" }
          ]
        },
        "timeline_phase": { "type": "string" },
        "phase": { "type": "string" },
        "related_events": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ad_res_j7_evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ad_res_j7_references": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_enhanced": { "type": "string" },
        "burden_of_proof": {
          "oneOf": [
            { "type": "string" },
            { "type": "object" }
          ]
        },
        "refinement_date": { "type": "string" },
        "criminal_threshold": { "type": ["string", "boolean"] },
        "evidence_strength": { "type": "string" }
      }
    }
  }
}
