# Database Configuration
# 
# This file documents the required environment variables for the project.
# Copy this file to .env and update with your actual values.

# PostgreSQL Database Connection
# Format: postgres://username:password@host:port/database
# 
# For local development with default PostgreSQL:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ad_res_j7

# For CI/Testing (GitHub Actions uses):
# DATABASE_URL=postgres://testuser:testpass@localhost:5432/testdb

# Alternative format using separate variables (if needed):
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ad_res_j7
